{
  "manifest_version": 2,
  "id": "github.bsfdsagfadg.maibot-plugin-ehentai",
  "version": "1.0.0",
  "name": "Ehentai\u4f7f\u7528\u63d2\u4ef6",
  "description": "\u4e3a MaiBot \u63d0\u4f9b E-Hentai \u753b\u5eca\u641c\u7d22\u3001\u5143\u6570\u636e\u89e3\u6790\u4e0e\u591a\u6a21\u6001\u9605\u8bfb\u80fd\u529b\u3002",
  "author": {
    "name": "bsfdsagfadg",
    "url": "https://github.com/bsfdsagfadg"
  },
  "license": "AGPL-3.0",
  "urls": {
    "repository": "https://github.com/bsfdsagfadg/maibot-plugin-ehentai"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "plugin_type": "tool",
  "display": {
    "icon": {
      "type": "lucide",
      "value": "book-open"
    }
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "requests",
      "version_spec": ">=2.28.0"
    },
    {
      "type": "python_package",
      "name": "beautifulsoup4",
      "version_spec": ">=4.11.0"
    },
    {
      "type": "python_package",
      "name": "pillow",
      "version_spec": ">=9.0.0"
    },
    {
      "type": "python_package",
      "name": "cachetools",
      "version_spec": ">=5.0.0"
    }
  ],
  "capabilities": [
    "send_message"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  }
}